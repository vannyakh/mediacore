USE_SQLITE=true
DATABASE_URL=postgresql+psycopg://mediacore:mediacore@localhost:5432/mediacore
DATABASE_URL_FALLBACK=sqlite+pysqlite:///./data/mediacore.db
REDIS_URL=redis://localhost:6379/0
SEED_API_KEY=dev-api-key-change-me
JWT_SECRET=dev-jwt-secret-change-me
STORAGE_ROOT=./data/files
# local (default) | s3 | r2 | gdrive | azure | dropbox | onedrive | ftp | webdav
STORAGE_BACKEND=local
# Optional cloud credentials — only needed when STORAGE_BACKEND != local
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# FTP_HOST=
# WEBDAV_URL=
JOB_TTL_HOURS=24
ALLOW_PRIVATE_URLS=false
SYNC_DOWNLOAD=true
DRAMATIQ_STUB=false
CORS_ORIGINS=*
APP_NAME=MediaCore
